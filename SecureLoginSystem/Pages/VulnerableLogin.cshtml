@page
@model SecureLoginSystem.Pages.VulnerableLoginModel
@{
    ViewData["Title"] = "Vulnerable Login";
}

<h1>Vulnerable Login - SQL Injection Demo</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <h3>@Model.Message</h3>
}

<form method="post">
    <div>
        <label>Username</label>
        <input asp-for="Username" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="Password" />
    </div>

    <button type="submit">Login</button>
</form>

@if (!string.IsNullOrEmpty(Model.QueryUsed))
{
    <hr />
    <h3>SQL Query Used:</h3>
    <pre>@Model.QueryUsed</pre>
}