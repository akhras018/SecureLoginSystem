@page
@model SecureLoginSystem.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<style>
    body {
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg, #dbeafe, #eff6ff, #ffffff);
        font-family: Arial, sans-serif;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .card-box {
        width: 100%;
        max-width: 430px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        padding: 35px;
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        color: #1e3a8a;
        margin-bottom: 10px;
    }

    .subtitle {
        text-align: center;
        color: #6b7280;
        margin-bottom: 25px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 7px;
        font-weight: bold;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        font-size: 15px;
        box-sizing: border-box;
    }

    .btn-main {
        width: 100%;
        background: #2563eb;
        color: white;
        border: none;
        padding: 13px;
        border-radius: 12px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-main:hover {
            background: #1d4ed8;
        }

    .text-danger {
        color: red;
        font-size: 13px;
    }

    .message-success {
        margin-bottom: 15px;
        padding: 10px;
        border-radius: 10px;
        background-color: #dcfce7;
        color: #166534;
        text-align: center;
    }
</style>

<div class="page-wrapper">
    <div class="card-box">
        <div class="title">Create New Password</div>
        <div class="subtitle">You cannot restore the old password. Enter a new one.</div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="message-success">@Model.SuccessMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Username" />

            <div class="form-group">
                <label asp-for="Input.NewPassword" class="form-label"></label>
                <input asp-for="Input.NewPassword" type="password" class="form-control" placeholder="Enter new password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-main">Save New Password</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}