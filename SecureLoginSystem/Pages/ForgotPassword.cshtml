@page
@model SecureLoginSystem.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    body {
        margin: 0;
        padding: 0;
        background: linear-gradient(135deg, #dbeafe, #eff6ff, #ffffff);
        font-family: Arial, sans-serif;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .card-box {
        width: 100%;
        max-width: 420px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        padding: 35px;
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        color: #1e3a8a;
        margin-bottom: 10px;
    }

    .subtitle {
        text-align: center;
        color: #6b7280;
        margin-bottom: 25px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 7px;
        font-weight: bold;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        font-size: 15px;
        box-sizing: border-box;
    }

    .btn-main {
        width: 100%;
        background: #2563eb;
        color: white;
        border: none;
        padding: 13px;
        border-radius: 12px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-main:hover {
            background: #1d4ed8;
        }

    .text-danger {
        color: red;
        font-size: 13px;
    }

    .message-box {
        margin-bottom: 15px;
        padding: 10px;
        border-radius: 10px;
        background-color: #fee2e2;
        color: #991b1b;
        text-align: center;
    }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 15px;
        text-decoration: none;
        color: #2563eb;
        font-weight: bold;
    }
</style>

<div class="page-wrapper">
    <div class="card-box">
        <div class="title">Forgot Password</div>
        <div class="subtitle">Enter your username to create a new password</div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="message-box">@Model.Message</div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.Username" class="form-label"></label>
                <input asp-for="Input.Username" class="form-control" placeholder="Enter username" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-main">Continue</button>
        </form>

        <a href="/Login" class="back-link">Back to Login</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}